# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for JWT signing)
STUDENT_ID_PREFIX=STU     # Prefix for automatically generated student User IDs (e.g., STU0001)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dbname  # PostgreSQL connection string

# ── Razorpay ───────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
